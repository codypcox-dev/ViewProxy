{
  "manifest_version": 3,
  "name": "ViewProxy",
  "version": "1.1.0",
  "description": "Watch or Focus any page region: pixel stream proxy, or live interactive clipped tab. 100% local — no tracking.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "ViewProxy — Watch or Focus a region",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "select-region": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "Alt+Shift+R"
      },
      "description": "Select a page region to stream"
    },
    "stop-stream": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Stop ViewProxy stream"
    },
    "video-crop": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "Alt+Shift+C"
      },
      "description": "Crop a <video> into Picture-in-Picture"
    },
    "open-panel": {
      "description": "Open ViewProxy control panel"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus"
  ]
}
